{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File C:\\Users\\user\\.claude\\hooks\\session-autopull.ps1"
          },
          {
            "type": "command",
            "command": "bash C:/Users/user/.claude/hooks/session-init.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/Users/user/.claude/hooks/permission-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/Users/user/.claude/hooks/pre-commit-lint.sh",
            "if": "Bash(git commit*)",
            "timeout": 60,
            "statusMessage": "린트 검사 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/Users/user/.claude/hooks/bellows-log.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "harness@harness-marketplace": true
  },
  "extraKnownMarketplaces": {
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      }
    }
  },
  "tui": "fullscreen",
  "theme": "dark"
}
