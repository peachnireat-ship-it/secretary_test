{
  "expo": {
    "name": "내 서재",
    "slug": "mybookshelf",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "mybookshelf",
    "android": {
      "package": "com.example.mybookshelf",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "책 인증을 위해 카메라 권한이 필요합니다.",
          "microphonePermission": "비디오 촬영 시 마이크 권한이 필요합니다."
        }
      ],
      "expo-video"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a3e18d6e-0977-4035-ac5c-8d55eb58c8a5"
      }
    }
  }
}
